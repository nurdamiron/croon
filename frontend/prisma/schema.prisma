generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String?
  phone        String?
  role         Role       @default(USER)
  emailNotifications Boolean @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  orders              Order[]
  favorites           Favorite[]
  pushSubscriptions   PushSubscription[]
  passwordResetTokens PasswordResetToken[]
  reviews             Review[]
  addresses           Address[]
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  address   String
  city      String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

enum Role {
  USER
  ADMIN
}

model Category {
  id          String     @id
  name        String
  slug        String     @unique
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  imageUrl    String?
  description String?    @db.Text
  isHidden    Boolean    @default(false)
  sortOrder   Int        @default(0)
  products    Product[]  @relation("PrimaryCategory")
  allProducts Product[]  @relation("ProductCategories")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Product {
  id          String         @id
  name        String
  slug        String         @unique
  description String?        @db.Text
  price       Float
  oldPrice    Float?
  inStock     Boolean        @default(false)
  // Архив: товар скрыт с сайта/Google/каналов/основного списка админки, но НЕ удалён
  // (сохраняется история продаж). Виден в админке через фильтр «Архив», можно вернуть.
  // Авто-архивация при попытке удалить товар, по которому есть продажи на сайте.
  archived    Boolean        @default(false)
  totalStock  Int            @default(0)
  // Зарезервировано под незавершённые Kaspi-заказы (бронь). Доступный остаток
  // для фида и сайта = totalStock − reservedStock. При выдаче заказа (COMPLETED)
  // totalStock уменьшается, reservedStock тоже; при отмене/возврате reservedStock
  // возвращается. Ручные правки склада трогают только totalStock.
  reservedStock   Int        @default(0)
  // Очередь синхронизации остатков с Satu: ставится true при любом изменении
  // остатка (заказ сайта/Kaspi/Satu, ручная правка). Воркер пушит в Satu только
  // товары с satuDirty=true и снимает флаг. См. lib/satu-sync.ts pushSatuDirty.
  satuDirty       Boolean    @default(false)
  costPrice       Float?
  costPriceDate   DateTime?
  weight          Float?
  // SKU товара. Якорь привязки каналов (Kaspi/Satu/Ba3ar ищут товар по SKU).
  // Этап 1 миграции «1 карточка = 1 товар»: переносим SKU с тех-варианта на Product.
  // Пока вариант ещё существует — sku зеркалится в обе стороны. nullable: товары без
  // SKU допустимы (Postgres разрешает несколько NULL при @unique).
  sku             String?    @unique
  metaTitle       String?
  metaDescription String?    @db.Text
  // Текст наклейки/бейджа на карточке (рядом со скидкой). Напр. «С НДС · растаможен»,
  // «Происхождение 2» — преимущество для B2B. Пусто/null → наклейки нет.
  badgeText       String?
  variantAttributes String[] @default([])
  categoryId      String?
  category    Category?      @relation("PrimaryCategory", fields: [categoryId], references: [id])
  categories  Category[]     @relation("ProductCategories")
  images      ProductImage[]
  changeLogs  ProductChangeLog[]
  favorites      Favorite[]
  orderItems     OrderItem[]
  reviews        Review[]
  viewedInOrders OrderViewedProduct[]
  kaspiOffers    KaspiOffer[]
  kaspiOrderItems KaspiOrderItem[]
  satuProducts   SatuProduct[]
  satuOrderItems SatuOrderItem[]
  ba3arOrderItems Ba3arOrderItem[]
  ba3arViewedInOrders Ba3arOrderViewedProduct[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([categoryId])
  @@index([slug])
  @@index([satuDirty])
}

model KaspiCatalogEntry {
  id             String   @id @default(cuid())
  kaspiSku       String   @unique
  kaspiProductId String?  // kaspi product id из URL карточки (вводится админом)
  kaspiUrl       String?  // полный URL карточки (вводится админом)
  name           String
  brand          String?
  priceTenge     Int
  cityId         String   @default("750000000")
  storeId        String   @default("30233309_PP1")
  available      Boolean  @default(false)
  importedAt     DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([kaspiProductId])
}

// Глобальные настройки-тумблеры (key-value). Для аварийных переключателей,
// которые меняются «на лету» без правки .env и рестарта.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model KaspiOffer {
  id           String   @id @default(cuid())
  kaspiSku     String   @unique
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  kaspiUrl     String?
  kaspiStoreId String   @default("30233309_PP1")
  priceTenge   Int
  cityId       String   @default("750000000")
  active       Boolean  @default(true)
  kaspiName    String?
  kaspiBrand   String?
  // Override-поля: если null/0 — используется значение из Product.totalStock/inStock
  stockOverride     Int?
  availableOverride Boolean?
  preOrder          Int   @default(0)
  // Показывать блок «Купить на Kaspi» на странице товара.
  // null = авто (как active/в фиде), true = всегда показывать, false = скрыть.
  showOnSite        Boolean?
  lastSyncedAt DateTime?

  // --- Демпинг (автоматическое управление ценой) ---
  // Два независимых тумблера: можно только снижать (держать топ), только повышать
  // (вернуть маржу когда конкурент ушёл), или оба.
  autoDownscale   Boolean  @default(false) // опускать цену под конкурента (до floor)
  autoUpscale     Boolean  @default(false) // поднимать к ceiling когда конкурентов нет
  minPriceTenge   Int?                       // floor — ниже не опускаемся
  maxPriceTenge   Int?                       // ceiling — выше не поднимаемся
  dumpingStep     Int      @default(2)       // на сколько тенге ниже конкурента
  strategy        String   @default("BECOME_FIRST") // BECOME_FIRST | MATCH_FIRST | HOLD_SECOND
  ignoreMerchants String[] @default([])      // merchantId, кого НЕ обгонять (свои/партнёры)
  // Снятые метрики (мониторинг, обновляются движком при каждом прогоне)
  firstPlacePrice Int?                        // цена лидера выдачи (из offer-view)
  rivalPrice      Int?                        // цена релевантного конкурента: мы 1-е → второй; мы 2+ → первый
  rivalName       String?                     // имя продавца релевантного конкурента (для игнор-листа и показа в строке)
  ourPosition     Int?                        // наше место (1 = первые)
  competitorCount Int?                        // число конкурентов (без нас и ignore)
  lastDumpCheckAt DateTime?                   // когда последний раз проверяли
  lastDumpError   String?                     // текст последней ошибки (null = ок)
  // Приоритетный демпинг: товары, где конкуренты активно демпингуют. Воркер
  // проверяет их ПЕРВЫМИ в каждом прогоне (не ждут своей очереди по кругу).
  dumpPriority    Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([productId])
  @@index([active])
  @@index([autoDownscale])
  @@index([autoUpscale])
  @@index([dumpPriority])
}

// Заказ, импортированный из Kaspi Merchant API (GET /shop/api/v2/orders).
// Read-only зеркало: статусы тянутся из Kaspi, обратно мы (пока) не пишем.
// Жизненный цикл остатков завязан на status (см. lib/kaspi-sync.ts):
//   APPROVED_BY_BANK → бронь (reservedStock += qty)
//   COMPLETED        → списание (totalStock -= qty, reservedStock -= qty)
//   CANCELLED/RETURNED → снять бронь (reservedStock -= qty)
model KaspiOrder {
  id            String   @id @default(cuid())
  kaspiOrderId  String   @unique          // id заказа в Kaspi (data.id)
  code          String                     // человекочитаемый номер заказа Kaspi
  state         String                     // NEW|SIGN_REQUIRED|PICKUP|DELIVERY|KASPI_DELIVERY|ARCHIVE
  status        String                     // APPROVED_BY_BANK|ACCEPTED_BY_MERCHANT|COMPLETED|CANCELLED|...
  // stockApplied — какой эффект на остатки уже применён, чтобы синк был
  // идемпотентным и не задваивал бронь/списание: null | "reserved" | "completed" | "released"
  stockApplied  String?
  totalPrice    Float    @default(0)
  customerName  String?
  customerPhone String?
  deliveryMode  String?
  isPreorder    Boolean  @default(false)
  isKaspiDelivery Boolean @default(false)
  creationDate  DateTime?                  // дата создания заказа в Kaspi
  raw           Json?                      // полный attributes на случай отладки
  items         KaspiOrderItem[]
  syncedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([state])
  @@index([creationDate])
}

model KaspiOrderItem {
  id           String     @id @default(cuid())
  kaspiOrderId String
  order        KaspiOrder @relation(fields: [kaspiOrderId], references: [id], onDelete: Cascade)
  kaspiSku     String                       // merchant SKU позиции (ProductAttributes.code)
  kaspiName    String?
  productId    String?                      // привязка к Product (через KaspiOffer/каталог), null если не сопоставлено
  product      Product?   @relation(fields: [productId], references: [id])
  quantity     Int        @default(1)
  price        Float      @default(0)

  @@index([kaspiOrderId])
  @@index([productId])
  @@index([kaspiSku])
}

// Зеркало товара на Satu.kz (импорт из products/list). Связь с товаром Alash
// через productId (авто по sku=артикул, либо вручную в /admin/satu).
// Используется для push остатков Alash → Satu (products/edit).
model SatuProduct {
  id          String   @id @default(cuid())
  satuId      String   @unique          // id товара в Satu (products/list .id)
  sku         String?                    // артикул на Satu («Код») — совпадает с артикулом Alash
  name        String
  presence    String?                    // available | order | not_available (последнее известное на Satu)
  price       Float?
  productId   String?                    // привязка к Product Alash (null = не сопоставлено)
  product     Product? @relation(fields: [productId], references: [id])
  active      Boolean  @default(true)    // участвует в push остатков
  lastPushedAt DateTime?                 // когда последний раз отправляли остаток в Satu
  raw         Json?
  importedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@index([sku])
}

// Заказ с Satu.kz (импорт из orders/list). Read-only зеркало. Логика остатков
// та же, что у Kaspi (reserved/completed/released через stockApplied).
model SatuOrder {
  id            String   @id @default(cuid())
  satuOrderId   String   @unique          // orders/list .id
  status        String                     // статус заказа Satu
  stockApplied  String?                    // null|reserved|completed|released (идемпотентность)
  totalPrice    Float    @default(0)
  customerName  String?
  customerPhone String?
  email         String?
  deliveryName  String?
  creationDate  DateTime?
  raw           Json?
  items         SatuOrderItem[]
  statusLogs    SatuOrderStatusLog[]
  syncedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([creationDate])
}

// История смены статусов заказа Satu (для карточки заказа).
model SatuOrderStatusLog {
  id          String    @id @default(cuid())
  satuOrderId String
  order       SatuOrder @relation(fields: [satuOrderId], references: [id], onDelete: Cascade)
  fromStatus  String?
  toStatus    String
  note        String?
  createdAt   DateTime  @default(now())

  @@index([satuOrderId])
}

model SatuOrderItem {
  id          String    @id @default(cuid())
  satuOrderId String
  order       SatuOrder @relation(fields: [satuOrderId], references: [id], onDelete: Cascade)
  satuItemId  String?                      // id позиции/товара в Satu
  sku         String?
  name        String?
  productId   String?                      // привязка к Product Alash
  product     Product?  @relation(fields: [productId], references: [id])
  quantity    Int       @default(1)
  price       Float     @default(0)

  @@index([satuOrderId])
  @@index([productId])
  @@index([sku])
}

// Заказы с ba3ar.kz (единый склад с Alash). ba3ar — та же БД, отдельный канал.
// Бронь/списание остатков по статусу (как Satu): stockApplied для идемпотентности.
model Ba3arOrder {
  id            String   @id @default(cuid())
  ba3arOrderId  String   @unique          // id заказа в ba3ar (uuid, ключ идемпотентности)
  orderNumber   Int      @unique @default(autoincrement()) // человекочитаемый № (старт 10000)
  status        String   @default("new")  // new|confirmed|processing|shipped|delivered|picked_up|canceled|returned
  stockApplied  String?                    // null|reserved|completed|released
  isPreorder    Boolean  @default(false)   // заказ содержит товар не в наличии (предзаказ)
  totalPrice    Float    @default(0)
  customerName  String?
  customerPhone String?
  email         String?
  deliveryName  String?                    // способ доставки
  paymentName   String?                    // способ оплаты
  address       String?
  comment       String?
  raw           Json?
  items         Ba3arOrderItem[]
  statusLogs    Ba3arOrderStatusLog[]
  viewedProducts Ba3arOrderViewedProduct[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// Товары, которые клиент смотрел перед заказом на витрине ba3ar (как у Alash).
model Ba3arOrderViewedProduct {
  id           String     @id @default(cuid())
  ba3arOrderId String
  order        Ba3arOrder @relation(fields: [ba3arOrderId], references: [id], onDelete: Cascade)
  sku          String?
  name         String?
  productId    String?                     // привязка к Product Alash (по sku)
  product      Product?   @relation(fields: [productId], references: [id])

  @@index([ba3arOrderId])
  @@index([productId])
}

// История смены статусов заказа ba3ar (для карточки заказа, как у Alash).
model Ba3arOrderStatusLog {
  id           String     @id @default(cuid())
  ba3arOrderId String
  order        Ba3arOrder @relation(fields: [ba3arOrderId], references: [id], onDelete: Cascade)
  fromStatus   String?
  toStatus     String
  note         String?
  createdAt    DateTime   @default(now())

  @@index([ba3arOrderId])
}

model Ba3arOrderItem {
  id           String     @id @default(cuid())
  ba3arOrderId String
  order        Ba3arOrder @relation(fields: [ba3arOrderId], references: [id], onDelete: Cascade)
  sku          String?                     // артикул (связь с Alash)
  name         String?
  productId    String?                     // привязка к Product Alash (по sku)
  product      Product?   @relation(fields: [productId], references: [id])
  quantity     Int        @default(1)
  price        Float      @default(0)

  @@index([ba3arOrderId])
  @@index([productId])
  @@index([sku])
}

// Результат сопоставления каталога ba3ar.kz с товарами Alash (разовый матчинг).
// kind: matched (есть пара) | only_ba3ar (нет в Alash) | only_alash (нет в ba3ar).
// status: pending | confirmed | rejected — для ручной проверки в /admin/ba3ar-match.
model Ba3arMatch {
  id          String   @id @default(cuid())
  kind        String                       // matched | only_ba3ar | only_alash
  ba3arSku    String?                       // SKU товара в ba3ar
  ba3arTitle  String?                       // название в ba3ar
  ba3arImage  String?                       // URL фото ba3ar (S3)
  ba3arPrice  Int?                          // цена ba3ar, тг
  ba3arDesc   String?  @db.Text             // короткое описание ba3ar
  alashId     String?                       // Product.id в Alash (если matched/only_alash)
  alashName   String?                       // название в Alash
  alashImage  String?                       // URL фото Alash
  alashPrice  Int?                          // цена Alash, тг
  alashDesc   String?  @db.Text             // описание Alash
  score       Float?                        // уверенность матча 0..1
  status      String   @default("pending")  // pending | confirmed | rejected | not_in_alash
  stockQty    Int?                          // фактическое наличие на складе (вводит админ вручную)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([kind])
  @@index([status])
  @@index([ba3arSku])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int     @default(0)

  @@index([productId])
}

model ProductChangeLog {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  field     String   // "price", "oldPrice", "stock", "totalStock"
  oldValue  Float
  newValue  Float
  source    String   @default("admin")
  detail    String?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     Int         @unique @default(autoincrement())
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  status          OrderStatus @default(NEW)
  total           Float
  name            String
  phone           String
  email           String?
  address         String?
  deliveryMethod  String?
  paymentMethod   String?
  comment         String?     @db.Text
  isPreorder      Boolean     @default(false)
  referrer        String?     // откуда пришёл: google, instagram, direct...
  utmSource       String?     // utm_source
  utmMedium       String?     // utm_medium
  utmCampaign     String?     // utm_campaign
  items           OrderItem[]
  viewedProducts  OrderViewedProduct[]
  searchQueries   OrderSearchQuery[]
  statusLogs      OrderStatusLog[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum OrderStatus {
  NEW
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  PICKED_UP
  CANCELLED
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float

  @@index([orderId])
}

model OrderStatusLog {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status      String
  prevStatus  String?
  note        String?
  cancelledBy String?
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([createdAt])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model OrderViewedProduct {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model OrderSearchQuery {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  query     String

  @@index([orderId])
}

model SearchLog {
  id          String   @id @default(cuid())
  query       String
  resultsCount Int
  sessionId   String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([query])
}

model Page {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  blogSlug  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lead {
  id             String     @id @default(cuid())
  name           String
  category       String
  city           String
  address        String?
  phone          String?
  whatsappNumber String?
  waSource       String?
  website        String?
  websiteStatus  String
  socials        String?
  score          Int        @default(0)
  rating         Float?
  reviewsCount   Int?
  branchCount    Int?
  twogisUrl      String?
  message        String?    @db.Text
  whatsappLink   String?    @db.Text
  status         LeadStatus @default(NEW)
  note           String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([name, city])
}

enum LeadStatus {
  NEW
  SENT
  REPLIED
  CONVERTED
  REJECTED
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model Review {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating     Int
  text       String   @db.Text
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([userId, productId])
  @@index([productId])
  @@index([isApproved])
}
