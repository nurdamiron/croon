generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  name                String?
  phone               String?
  role                Role                 @default(USER)
  emailNotifications  Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  addresses           Address[]
  favorites           Favorite[]
  orders              Order[]
  passwordResetTokens PasswordResetToken[]
  pushSubscriptions   PushSubscription[]
  reviews             Review[]
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String
  address   String
  city      String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Category {
  id          String     @id
  name        String
  slug        String     @unique
  parentId    String?
  imageUrl    String?
  description String?
  isHidden    Boolean    @default(false)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]  @relation("PrimaryCategory")
  allProducts Product[]  @relation("ProductCategories")
}

model Product {
  id                String               @id
  name              String
  slug              String               @unique
  description       String?
  price             Float
  oldPrice          Float?
  inStock           Boolean              @default(false)
  archived          Boolean              @default(false)
  totalStock        Int                  @default(0)
  reservedStock     Int                  @default(0)
  costPrice         Float?
  costPriceDate     DateTime?
  weight            Float?
  sku               String?              @unique
  metaTitle         String?
  metaDescription   String?
  badgeText         String?
  variantAttributes String[]             @default([])
  categoryId        String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  favorites         Favorite[]
  kaspiOffers       KaspiOffer[]
  kaspiOrderItems   KaspiOrderItem[]
  orderItems        OrderItem[]
  viewedInOrders    OrderViewedProduct[]
  category          Category?            @relation("PrimaryCategory", fields: [categoryId], references: [id])
  changeLogs        ProductChangeLog[]
  images            ProductImage[]
  reviews           Review[]
  categories        Category[]           @relation("ProductCategories")

  @@index([categoryId])
  @@index([slug])
}

model KaspiCatalogEntry {
  id             String   @id @default(cuid())
  kaspiSku       String   @unique
  kaspiProductId String?
  kaspiUrl       String?
  name           String
  brand          String?
  priceTenge     Int
  cityId         String   @default("750000000")
  storeId        String   @default("30233309_PP1")
  available      Boolean  @default(false)
  importedAt     DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([kaspiProductId])
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model KaspiOffer {
  id                String    @id @default(cuid())
  kaspiSku          String    @unique
  productId         String
  kaspiUrl          String?
  kaspiStoreId      String    @default("30233309_PP1")
  priceTenge        Int
  cityId            String    @default("750000000")
  active            Boolean   @default(true)
  kaspiName         String?
  kaspiBrand        String?
  stockOverride     Int?
  availableOverride Boolean?
  preOrder          Int       @default(0)
  showOnSite        Boolean?
  // Dumping fields
  autoDownscale     Boolean   @default(false)
  autoUpscale       Boolean   @default(false)
  minPriceTenge     Int?
  maxPriceTenge     Int?
  dumpingStep       Int       @default(2)
  strategy          String    @default("BECOME_FIRST")
  ignoreMerchants   String[]
  dumpPriority      Boolean   @default(false)
  // Metrics (updated by dumping engine)
  firstPlacePrice   Int?
  rivalPrice        Int?
  rivalName         String?
  ourPosition       Int?
  competitorCount   Int       @default(0)
  lastDumpCheckAt   DateTime?
  lastSyncedAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([active])
  @@index([autoDownscale])
  @@index([lastDumpCheckAt])
}

model KaspiOrder {
  id              String           @id @default(cuid())
  kaspiOrderId    String           @unique
  code            String
  state           String
  status          String
  stockApplied    String?
  totalPrice      Float            @default(0)
  customerName    String?
  customerPhone   String?
  deliveryMode    String?
  isPreorder      Boolean          @default(false)
  isKaspiDelivery Boolean          @default(false)
  creationDate    DateTime?
  raw             Json?
  syncedAt        DateTime         @default(now())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  items           KaspiOrderItem[]

  @@index([status])
  @@index([state])
  @@index([creationDate])
}

model KaspiOrderItem {
  id           String     @id @default(cuid())
  kaspiOrderId String
  kaspiSku     String
  kaspiName    String?
  productId    String?
  quantity     Int        @default(1)
  price        Float      @default(0)
  order        KaspiOrder @relation(fields: [kaspiOrderId], references: [id], onDelete: Cascade)
  product      Product?   @relation(fields: [productId], references: [id])

  @@index([kaspiOrderId])
  @@index([productId])
  @@index([kaspiSku])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Supplier {
  id          String         @id @default(cuid())
  name        String
  contactInfo String?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  receipts    StockReceipt[]

  @@index([name])
}

model StockReceipt {
  id          String             @id @default(cuid())
  batchNumber String?            @unique
  name        String?
  supplierId  String?
  notes       String?
  totalItems  Int                @default(0)
  totalQty    Int                @default(0)
  totalCost   Float              @default(0)
  createdAt   DateTime           @default(now())
  createdBy   String?
  changeLogs  ProductChangeLog[]
  supplier    Supplier?          @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
  @@index([createdAt])
}

model ProductChangeLog {
  id             String        @id @default(cuid())
  productId      String
  field          String
  oldValue       Float
  newValue       Float
  source         String        @default("admin")
  detail         String?
  createdAt      DateTime      @default(now())
  stockReceiptId String?
  product        Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockReceipt   StockReceipt? @relation(fields: [stockReceiptId], references: [id])

  @@index([productId])
  @@index([createdAt])
  @@index([stockReceiptId])
}

model Order {
  id             String               @id @default(cuid())
  orderNumber    Int                  @unique @default(autoincrement())
  userId         String?
  status         OrderStatus          @default(NEW)
  total          Float
  name           String
  phone          String
  email          String?
  address        String?
  deliveryMethod String?
  paymentMethod  String?
  comment        String?
  isPreorder     Boolean              @default(false)
  referrer       String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  user           User?                @relation(fields: [userId], references: [id])
  items          OrderItem[]
  searchQueries  OrderSearchQuery[]
  statusLogs     OrderStatusLog[]
  viewedProducts OrderViewedProduct[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model OrderStatusLog {
  id          String   @id @default(cuid())
  orderId     String
  status      String
  prevStatus  String?
  note        String?
  cancelledBy String?
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model OrderViewedProduct {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model OrderSearchQuery {
  id      String @id @default(cuid())
  orderId String
  query   String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model SearchLog {
  id           String   @id @default(cuid())
  query        String
  resultsCount Int
  sessionId    String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([query])
}

model Page {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  blogSlug  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lead {
  id             String     @id @default(cuid())
  name           String
  category       String
  city           String
  address        String?
  phone          String?
  whatsappNumber String?
  waSource       String?
  website        String?
  websiteStatus  String
  socials        String?
  score          Int        @default(0)
  rating         Float?
  reviewsCount   Int?
  branchCount    Int?
  twogisUrl      String?
  message        String?
  whatsappLink   String?
  status         LeadStatus @default(NEW)
  note           String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([name, city])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Review {
  id         String   @id @default(cuid())
  userId     String
  productId  String
  rating     Int
  text       String
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([isApproved])
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  NEW
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  PICKED_UP
  CANCELLED
}

enum LeadStatus {
  NEW
  SENT
  REPLIED
  CONVERTED
  REJECTED
}
