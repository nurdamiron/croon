# PostgreSQL — Supabase
# DATABASE_URL: Connection Pooler (Transaction Mode, port 6543)
DATABASE_URL="postgres://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL: Direct Connection (Session Mode/Direct, port 5432) for migrations
DIRECT_URL="postgres://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# NextAuth
NEXTAUTH_SECRET="your-random-secret-32-chars"
NEXTAUTH_URL=https://alash-electronics.kz
#
# Локальная разработка (скопируйте в .env.local):
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=<случайная строка 32+ символов>
# DATABASE_URL=<postgres куда вы подключаетесь: локально или RDS с вашим IP в security group>
# После регистрации пользователя выдайте роль ADMIN в БД: UPDATE "User" SET role = 'ADMIN' WHERE email = '...';

# AWS S3 — bucket: alashed-media (eu-north-1)
# IAM user: alashed-media (S3 access only)
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Web Push (PWA push notifications)
# Generate: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Server port
# PROD (EC2): PORT=5000  ← nginx proxy_pass → 127.0.0.1:5000
# LOCAL dev:  PORT=3000
PORT=3000

# --- Google Indexing API (опционально, только для скрипта scripts/google-index-urls.js) ---
# JSON ключ сервисного аккаунта; НЕ коммитить. В Search Console добавить client_email как владельца.
# В GCP включить API "Indexing API". Квота по умолчанию ~200 URL/сутки.
# GOOGLE_INDEXING_KEY_PATH=/absolute/path/to/service-account.json
# SITE_URL=https://alash-electronics.kz
# GOOGLE_INDEXING_STATE_PATH=/absolute/path/google-indexing-state.json  # опционально; иначе frontend/scripts/google-indexing-state.json

# --- Kaspi.kz интеграция ---
# Переключатель режима: prod | test. Меняешь одну строку — переключаешься
# между рабочим и тестовым токеном. По умолчанию prod.
# KASPI_MODE=prod
# Токены API из Merchant Cabinet. Заполни оба — переключение через KASPI_MODE.
# KASPI_API_TOKEN_PROD=   # рабочий токен
# KASPI_API_TOKEN_TEST=   # тестовый токен (sandbox/тест-кабинет)
# (legacy) старый общий токен — используется как fallback, если PROD/TEST не заданы
# KASPI_API_TOKEN=
# Идентификатор магазина в Kaspi
# KASPI_MERCHANT_ID=30233309
# Опционально: Basic Auth для /api/kaspi/feed.xml — если задано, Kaspi должен слать те же креды
# KASPI_FEED_USER=
# KASPI_FEED_PASS=
# Опционально: базовый URL Kaspi API по режимам (по умолчанию https://kaspi.kz/shop/api/v2)
# KASPI_API_URL_PROD=
# KASPI_API_URL_TEST=
# KASPI_API_URL=   # legacy fallback
# Секрет для cron-эндпоинта синхронизации заказов /api/cron/kaspi-sync
# (cron на EC2 шлёт Authorization: Bearer <CRON_SECRET>). Сгенерировать: openssl rand -hex 24
# CRON_SECRET=

# --- Satu.kz интеграция ---
# API-токен из кабинета Satu: Настройки → Управление API-токенами
# SATU_API_TOKEN=
# Опционально: переопределить базовый URL Satu API (по умолчанию https://my.satu.kz/api/v1)
# SATU_API_URL=

# Email (SMTP Gmail) — для уведомлений клиентам (подтверждение заказа, смена статуса, сброс пароля)
# Gmail: включи 2FA → Google Account → Security → App Passwords → создай пароль приложения
# SMTP_USER=alash.electronics@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx   # App Password (16 символов без пробелов)
# SMTP_HOST=smtp.gmail.com        # опционально, по умолчанию smtp.gmail.com
# SMTP_PORT=465                   # опционально, по умолчанию 465 (SSL); 587 = STARTTLS
# EMAIL_FROM=Alash Electronics <alash.electronics@gmail.com>  # опционально

# Internal API key for Biz platform server-to-server calls (POST /api/internal/products)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=your-random-internal-api-key

# Outbound push of admin notifications into the Biz operational brain (its existing
# POST /api/internal/activity). Both must be set to enable forwarding; BIZ_INTERNAL_KEY
# must equal Biz's own INTERNAL_API_KEY env value.
BIZ_INTERNAL_URL=https://api.biz.alashed.kz
BIZ_INTERNAL_KEY=biz-internal-api-key


